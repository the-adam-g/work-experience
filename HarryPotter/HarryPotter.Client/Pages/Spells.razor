@page "/spells" 
@using Blazorise.LoadingIndicator
@using HarryPotter.Client.Core.Models @* Import classes *@
@using HarryPotter.Client.Core.Services
@using HarryPotter.Server.Models @* import more classes *@
@inject HarryPotterService HarryPotterService
@* Defines a new URL directory for the file *@

<h1><b>Spells Challenge</b></h1>

<p>
    This page is intentionally unfinished. Use the <b>Characters</b> page as your reference, then build the Spells feature yourself.
</p>

<h4><b>Your goal</b></h4>

<ol>
    <li>Create a spell model with the properties you need.</li>
    <li>Add the server-side endpoint flow for spells.</li>
    <li>Add the client-side service method for spells.</li>
    <li>Load the data into this page.</li>
    <li>Display the results and add a simple search.</li>
</ol>

<h4><b>Files you will probably change</b></h4>

<ul>
    <li>Client model</li>
    <li>Client <code>HarryPotterService</code></li>
    <li>Server service interface</li>
    <li>Server <code>HarryPotterController</code></li>
    <li>Server <code>HarryPotterService</code></li>
    <li>This Razor page</li>
</ul>

<h4><b>Starter layout</b></h4>

<p>
    The search box and table shape are already here so you have a baseline to build on.
</p>

<div class="search-field">
    <Field Horizontal>
        <FieldLabel ColumnSize="ColumnSize.Is1">Name:</FieldLabel>
        <FieldBody ColumnSize="ColumnSize.Is4">
            <input class="form-control" placeholder="Wire this up once your spells are loading" disabled />
        </FieldBody>
    </Field>
</div>

<table class="table table-striped table-hover spells-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td colspan="2">Your spell data will appear here once you finish the feature.</td>
        </tr>
        @foreach (Spell spell in FilteredSpells)
        {
            <tr>
                <td>@spell.Name</td>
                <td>@spell.Description</td>
            </tr>
        }
    </tbody>
</table>

<h4><b>Success check</b></h4>

<ul>
    <li>The page loads spell data from the API.</li>
    <li>You can show information about the spells in a clear way.</li>
    <li>You can explain the flow from page -> client service -> controller -> server service -> HP API.</li>
</ul>

@{
    <style scoped>
        .search-field {
            padding: 10px;
        }

        .spells-table {
            margin-top: 10px;
        }
    </style>
}

@code {
    private string SpellSearchText = string.Empty;

    private bool IsLoading;

    private List<Spell> SpellList { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        SpellList = await HarryPotterService.GetSpellsAsync(); //Set spell link to API call 
        IsLoading = false;
    }
    private IEnumerable<Spell> FilteredSpells
    {
        get
        {
            if (string.IsNullOrWhiteSpace(SpellSearchText)) //if there is no data, ignore character
            {
                return SpellList;
            }
            return SpellList.Where(character =>
                character.Name?.Contains(SpellSearchText, StringComparison.OrdinalIgnoreCase) ?? false);
        }
    }
}